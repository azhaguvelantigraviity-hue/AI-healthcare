# Frontend Environment Variables
# Copy this file to .env and update the values for your environment.

# The URL of your deployed backend API
# If deployed on Render, it will look like: https://your-app.onrender.com
# If running locally, you can use http://localhost:5000
VITE_API_URL=https://your-backend-url.com

# Do NOT put MongoDB URIs or sensitive secrets in this file.
# This file is bundled with the frontend code.
